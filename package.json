{
  "name": "open-agent-platform",
  "version": "0.1.0",
  "description": "Open-source local-first desktop AI agent platform — execute tasks, not just chat. Inspired by Accio Work.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "tsc && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "example:core": "ts-node src/core/example.ts",
    "example:llm": "ts-node src/llm/examples.ts",
    "clean": "rm -rf dist release"
  },
  "dependencies": {
    "openai": "^4.60.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-cron": "^4.2.1",
    "puppeteer-core": "^23.0.0",
    "telegraf": "^4.16.0",
    "discord.js": "^14.16.0",
    "@slack/web-api": "^7.5.0",
    "@slack/socket-mode": "^2.0.0",
    "chokidar": "^4.0.0",
    "glob": "^10.0.0",
    "zustand": "^5.0.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.26.0",
    "lucide-react": "^0.400.0",
    "react-markdown": "^9.0.0",
    "highlight.js": "^11.10.0",
    "uuid": "^10.0.0",
    "electron-store": "^10.0.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "vitest": "^2.0.0",
    "eslint": "^9.10.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "agent", "ai", "automation", "llm", "desktop", "electron",
    "multi-agent", "mcp", "openai", "anthropic", "gemini", "ollama",
    "local-first", "task-execution", "browser-automation"
  ],
  "author": "OpenAgentPlatform Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-agent-platform/oap"
  }
}
