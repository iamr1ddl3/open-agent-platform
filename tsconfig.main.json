{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/core/**/*",
    "src/tools/**/*",
    "src/llm/**/*",
    "src/mcp/**/*",
    "src/skills/**/*",
    "src/teams/**/*",
    "src/scheduler/**/*",
    "src/channels/**/*"
  ],
  "exclude": ["src/renderer/**/*"]
}
